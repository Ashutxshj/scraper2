# --- Delivery (wa1.txt / report-generator theory: Resend + attachment) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender/domain in your Resend account
RESEND_FROM_EMAIL=onboarding@resend.dev
# NOTE: plan says "ashutosh@06067gmail.com" — 06067gmail.com is not a real
# domain; if this bounces, the intended address is likely ashutosh06067@gmail.com
RECIPIENT_EMAIL=ashutosh06066@gmail.com

# --- Sourcing ---
# Precedence: Apify -> Google Places -> seed_places.csv -> built-in mock targets.
#
# Apify Google Maps Scraper — RECOMMENDED, no credit card required.
# Get a token: apify.com -> sign up (free plan, $5/mo credits) -> Settings -> API token.
# Setting APIFY_TOKEN makes it the sourcing method (ahead of Google Places).
APIFY_TOKEN=
APIFY_ACTOR_ID=compass/crawler-google-places
APIFY_MAX_PLACES_PER_SEARCH=20
APIFY_MAX_SEARCHES=20

# Google Places API (New) key with "Places API (New)" enabled.
# NOTE: Google requires a billing account + credit card even for the free tier.
GOOGLE_PLACES_API_KEY=

# --- Lead tiers ---
# Goldenrod = no website AND rating >= GOLDENROD_MIN_RATING AND
# reviews >= GOLDENROD_MIN_REVIEWS. Everything else (no website) = New Bark.
GOLDENROD_MIN_RATING=4.5
GOLDENROD_MIN_REVIEWS=500

# --- Scraper behaviour ---
REQUEST_DELAY_SECONDS=1.0
MAX_TARGETS=0

# --- Anti-ban: retry + backoff + jitter ---
MAX_RETRIES=3
BACKOFF_BASE_SECONDS=1.5
BACKOFF_MAX_SECONDS=30
# Randomized delay between requests (replaces the fixed cadence)
JITTER_MIN_SECONDS=0.8
JITTER_MAX_SECONDS=2.5

# --- Anti-ban: rotating proxies ---
# Either list here (comma-separated) and/or put one-per-line in proxies.txt.
# Format: scheme://[user:pass@]host:port   e.g. http://user:pass@1.2.3.4:8000
PROXY_LIST=
PROXY_FILE=proxies.txt
PROXY_MAX_FAILURES=3

# --- Output ---
# CSV + styled XLSX are archived (timestamped) here in addition to being emailed
OUTPUT_DIR=output
